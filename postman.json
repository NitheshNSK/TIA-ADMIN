          }
        }
      ]
    },

    {
      "name": "Students",
      "item": [
        {
          "name": "Add Student",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/admin/student",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"personalInfo\": {\n    \"studentName\": \"Test Student\",\n    \"phoneNumber\": \"8888888888\"\n  }\n}"
            }
          }
        },
        {
          "name": "Get Students",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/admin/student?page=1&limit=10"
          }
        },
        {
          "name": "Export Students Excel",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/admin/student/export"
          }
        }
      ]
    },

    {
      "name": "Email Templates",
      "item": [
        {
          "name": "Create Template",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/admin/email-template",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"templateName\": \"welcome_user\",\n  \"subject\": \"Welcome\",\n  \"htmlContent\": \"<h1>Hello {{username}}</h1>\",\n  \"variables\": [\"username\"]\n}"
            }
          }
        },
        {
          "name": "Get Templates",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/admin/email-template"
          }
        },
        {
          "name": "Update Template",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/admin/email-template/TEMPLATE_ID",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Updated Subject\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "Settings",
      "item": [
        {
          "name": "Get Settings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/admin/settings"
          }
        },
        {
          "name": "Update Settings",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/admin/settings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resendApiKey\": \"re_xxxxxxxxx\",\n  \"emailFromName\": \"TIA Support\",\n  \"emailFromAddress\": \"support@tiaedu.in\"\n}"
            }
          }
        }
      ]
    }
  ]
}
